{
  "version": "1.0",
  "description": "Action catalog for generic robot command routing.",
  "actions": [
    {
      "name": "move_joints",
      "command_name": "joint_move",
      "description": "Move one joint by a delta angle in degrees.",
      "handler": "move_joint",
      "parameters": {
        "joint": {
          "type": "integer",
          "minimum": 1,
          "maximum": 6,
          "required": true
        },
        "delta": {
          "type": "number",
          "minimum": -60,
          "maximum": 60,
          "required": true,
          "unit": "degrees"
        }
      },
      "prompt_pack": "move_joints.md",
      "simulator_only": true
    }
  ]
}
