{
  "name": "move_joints_v1",
  "description": "Single-joint movement command for Increment 1.",
  "json_schema": {
    "command_name": "string",
    "parameters": {
      "joint": "integer",
      "delta": "number"
    }
  },
  "rules": [
    "Always include 'command_name' and 'parameters'.",
    "Use command_name 'joint_move' only.",
    "Output exactly one joint and one delta.",
    "Numbers must be numeric, not strings.",
    "No markdown, no extra top-level keys."
  ],
  "examples": [
    {
      "input": "move joint one by 30 degrees",
      "output": {
        "command_name": "joint_move",
        "parameters": {
          "joint": 1,
          "delta": 30
        }
      }
    },
    {
      "input": "move J4 by minus 20",
      "output": {
        "command_name": "joint_move",
        "parameters": {
          "joint": 4,
          "delta": -20
        }
      }
    }
  ]
}
