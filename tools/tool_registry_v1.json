{
  "version": "1.0",
  "description": "Increment 1 tool registry with one simulator-only action.",
  "tools": [
    {
      "name": "move_joints",
      "intent": "joint_move",
      "description": "Move one joint by a delta angle in degrees.",
      "parameters": {
        "joint": {
          "type": "integer",
          "minimum": 1,
          "maximum": 6,
          "required": true
        },
        "delta": {
          "type": "number",
          "minimum": -60,
          "maximum": 60,
          "required": true,
          "unit": "degrees"
        }
      },
      "prompt_pack": "move_joints.md",
      "simulator_only": true
    }
  ]
}
